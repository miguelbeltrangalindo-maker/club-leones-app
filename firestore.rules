rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── HELPERS ──────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function myRoleDoc() {
      return get(/databases/$(database)/documents/roles/$(request.auth.uid));
    }

    function isActive() {
      return signedIn() &&
        exists(/databases/$(database)/documents/roles/$(request.auth.uid)) &&
        myRoleDoc().data.activo == true;
    }

    function isAdmin() {
      return isActive() &&
        myRoleDoc().data.rol == "admin";
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // ── USUARIOS (PERFIL) ────────────────────────────

    match /usuarios/{uid} {

      allow read: if isOwner(uid) || isAdmin();

      allow create: if isOwner(uid);

      allow update: if isOwner(uid) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          "nombre",
          "telefono",
          "fotoURL",
          "updatedAt"
        ]);

      allow delete: if false;
    }

    // ── ROLES (PRIVADO TOTAL) ───────────────────────

    match /roles/{uid} {
      allow read, write: if false;
    }

    // ── SOCIOS (DIRECTORIO) ─────────────────────────

    match /socios/{id} {

      // Solo usuarios activos pueden ver directorio
      allow read: if isActive();

      // Solo admin modifica
      allow create, update, delete: if isAdmin();
    }

    // ── COMUNICADOS ─────────────────────────────────

    match /comunicados/{id} {

      // Solo miembros activos ven avisos
      allow read: if isActive();

      // Solo admin publica
      allow create, update, delete: if isAdmin();
    }

    // ── SOLICITUDES (ADMIN) ─────────────────────────

    match /solicitudes/{id} {

      allow read, write: if isAdmin();
    }

    // ── FALLBACK (CERO ACCESO) ──────────────────────

    match /{document=**} {
      allow read, write: if false;
    }

  }
}